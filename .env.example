# Base de donnees SQLite.
# En LOCAL : chemin resolu par Prisma relativement au dossier prisma/ -> cree prisma/dev.db
DATABASE_URL="file:./dev.db"

# En PROD (Docker), on surcharge avec un chemin absolu sur le volume :
# DATABASE_URL="file:/data/arise.db"

# Secret pour proteger le cron de bascule de journee (mets une valeur aleatoire)
SYSTEM_CRON_SECRET="change-me"

# (Plus tard) Cles Web Push VAPID
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# (Plus tard) Auth
# AUTH_SECRET=
