# Base de donnees SQLite. En PROD (Docker) c'est surcharge par docker-compose.
DATABASE_URL="file:./dev.db"

# Secret protegeant le cron (/api/system/tick et /api/system/remind)
SYSTEM_CRON_SECRET="change-me"

# --- Web Push (Phase 3) ---
# Genere les tiennes avec : npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@leveling.matthomelab.tech"
